{
  "name": "gilly",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "dev:harness": "bun run --filter '@gilly/harness-claude' dev",
    "dev:control-plane": "bun run --filter '@gilly/control-plane' dev",
    "dev:gateway": "bun run --filter '@gilly/gateway' dev",
    "dev:web": "bun run --filter '@gilly/web' dev"
  },
  "dependencies": {
    "@gilly/gateway-client": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
