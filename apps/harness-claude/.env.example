# Harness — drives the agent loop. Supports multiple drivers behind the AgentCore HTTP contract.
# Bun auto-loads this file. Copy to `.env` and fill in.

# Which harness driver to use: "claude" (default) or "acp".
# HARNESS_DRIVER=claude

# --- Claude driver (default) ---
# Anthropic API key the SDK uses to drive the loop.
ANTHROPIC_API_KEY=

# --- ACP driver (HARNESS_DRIVER=acp) ---
# The command to spawn as the ACP-compatible agent process (stdio JSON-RPC).
# ACP_COMMAND=acp-agent
# Space-separated args for the ACP command.
# ACP_ARGS=

# Optional — port for the AgentCore contract (/invocations, /ping). Default 8080.
# PORT=8080
