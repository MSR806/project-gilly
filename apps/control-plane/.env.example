# Control plane — Slack assistant + web channel/API + session engine.
# Bun auto-loads this file (cwd is this dir when run via `bun run --filter`).
# Copy to `.env` and fill in.

# Slack assistant app — bot token (xoxb-...) and app-level token (xapp-...) for
# Socket Mode. Optional: leave blank to run the web UI/API without Slack.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Port for the web channel / management API the UI calls.
WEB_PORT=4000

# Local harness endpoint (AgentCore contract).
HARNESS_URL=http://localhost:8080

# Optional — defaults resolve against the repo root:
# AGENTS_DIR=config/agents
# DATABASE_PATH=data/gilly.db
# GILLY_AGENT_ID=echo
