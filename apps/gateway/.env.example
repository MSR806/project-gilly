# Tooling gateway — the single door for external/internal tool calls.
# Bun auto-loads this file (cwd is this dir when run via `bun run dev:gateway`).
# Copy to `.env` and fill in. Generate the two secrets with: openssl rand -hex 32

# Master secret for encrypting connector credentials at rest (AES-256-GCM,
# key = SHA-256 of this). Use a strong random value; changing it makes any
# already-stored credential undecryptable.
GILLY_VAULT_KEY=

# Shared secret gating the credential-write route (sent as the x-admin-token header).
GILLY_ADMIN_TOKEN=

# Port the gateway listens on (control-plane's GILLY_GATEWAY_URL must point here).
PORT=4100

# Optional — web app URL to return to after an OAuth connect (defaults to the dev web server).
# GILLY_WEB_URL=http://localhost:3000

# Optional — defaults to the shared repo-root DB:
# DATABASE_PATH=data/gilly.db
