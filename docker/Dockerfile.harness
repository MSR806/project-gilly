# Claude harness — implements the AgentCore runtime contract (/invocations, /ping on :8080).
# Same image runs locally and (later) inside AWS Bedrock AgentCore unchanged.
# Pinned to match the lockfile's bun so --frozen-lockfile stays stable.
FROM oven/bun:1.3.5 AS base
WORKDIR /app

# Copy the whole workspace so the frozen lockfile resolves every member.
COPY package.json bun.lock ./
COPY packages ./packages
COPY apps ./apps
RUN bun install --frozen-lockfile

EXPOSE 8080
CMD ["bun", "run", "--filter", "@gilly/harness-claude", "start"]
