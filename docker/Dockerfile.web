# Gilly web UI — Next.js app. Proxies /api/* to the control-plane (see API_URL).
# Pinned to match the lockfile's bun so --frozen-lockfile stays stable.
FROM oven/bun:1.3.5 AS base
WORKDIR /app

# Copy the whole workspace so the frozen lockfile resolves every member.
COPY package.json bun.lock ./
COPY packages ./packages
COPY apps ./apps
RUN bun install --frozen-lockfile

EXPOSE 3000
# `next dev` binds 0.0.0.0 by default, so it's reachable through the published port.
CMD ["bun", "run", "--filter", "@gilly/web", "dev"]
