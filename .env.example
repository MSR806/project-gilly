# All-in-one env template. Each app also auto-loads its own apps/<app>/.env
# (preferred) — this root file is the single-file alternative. Copy to `.env`.

# --- Harness (apps/harness-claude) ---
# Anthropic API key the Claude Agent SDK uses to drive the loop.
ANTHROPIC_API_KEY=

# --- Control plane (apps/control-plane) ---
# Slack connections are now created in the web UI (Connections page) and stored
# encrypted in SQLite — no Slack env vars here.

# Port for the web channel / management API the UI calls.
WEB_PORT=4000

# Where the local harness process listens (AgentCore contract).
HARNESS_URL=http://localhost:8080

# Tooling gateway endpoint — enables per-run token minting.
GILLY_GATEWAY_URL=http://localhost:4100

# Directory of *.json agent definitions, loaded at boot.
AGENTS_DIR=./config/agents

# SQLite operational store path.
DATABASE_PATH=./data/gilly.db

# --- Secrets (shared by the gateway AND control plane) ---
# Generate the two secrets with: openssl rand -hex 32
# Master secret for encrypting secrets at rest (AES-256-GCM): connector credentials
# (gateway) and Slack connection tokens (control plane). Required by both.
GILLY_VAULT_KEY=

# Shared secret gating the gateway's credential-write route (x-admin-token header).
GILLY_ADMIN_TOKEN=

# Port the gateway listens on (GILLY_GATEWAY_URL must point here).
PORT=4100
