# --- Harness (apps/harness-claude) ---
# Anthropic API key the Claude Agent SDK uses to drive the loop.
ANTHROPIC_API_KEY=

# --- Control plane (apps/control-plane) ---
# Slack bot token (xoxb-...) and app-level token (xapp-...) for Socket Mode.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Where the local harness container/process listens (AgentCore contract).
HARNESS_URL=http://localhost:8080

# Directory of *.json agent definitions, loaded at boot.
AGENTS_DIR=./config/agents

# SQLite operational store path.
DATABASE_PATH=./data/gilly.db
